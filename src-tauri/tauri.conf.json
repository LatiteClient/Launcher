{
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devPath": "http://localhost:1420",
    "distDir": "../src/dist",
    "withGlobalTauri": true
  },
  "package": {
    "productName": "Latite Client Launcher"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "shell": {
        "all": false,
        "open": true
      },
      "dialog": {
        "all": false,
        "message": true,
        "open": true
      },
      "clipboard": {
        "all": false,
        "readText": true
      },
      "window": {
        "all": false,
        "center": false,
        "close": false,
        "create": false,
        "hide": false,
        "maximize": false,
        "minimize": false,
        "print": false,
        "requestUserAttention": false,
        "setAlwaysOnTop": false,
        "setClosable": false,
        "setContentProtected": false,
        "setCursorGrab": false,
        "setCursorIcon": false,
        "setCursorPosition": false,
        "setCursorVisible": false,
        "setDecorations": false,
        "setFocus": false,
        "setFullscreen": false,
        "setIcon": false,
        "setIgnoreCursorEvents": false,
        "setMaxSize": false,
        "setMaximizable": false,
        "setMinSize": false,
        "setMinimizable": false,
        "setPosition": false,
        "setResizable": false,
        "setSize": false,
        "setSkipTaskbar": false,
        "setTitle": false,
        "show": false,
        "startDragging": true,
        "unmaximize": false,
        "unminimize": false
      },
      "os": {
        "all": true
      }
    },
    "windows": [
      {
        "fullscreen": false,
        "resizable": false,
        "title": "Latite Client Launcher",
        "width": 656,
        "height": 458,
        "decorations": false,
        "transparent": true
      }
    ],
    "systemTray": {
      "iconPath": "icons/icon.ico",
      "iconAsTemplate": false
    },
    "updater": {
      "active": true,
      "dialog": false,
      "endpoints": [
        "https://github.com/LatiteClient/Launcher/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDdGN0Y4QzY5NThCNkFGOTQKUldTVXI3WllhWXgvZno1U1lXN09Xc2cxK1RHQ29EQlVYOWNmUXdvelFyMXVrNmJyYVNRbEYxSlkK",
      "windows": {
        "installMode": "passive"
      }
    },
    "security": {
      "csp": null
    },
    "bundle": {
      "active": true,
      "targets": ["nsis", "updater"],
      "identifier": "net.latite.launcher",
      "icon": [
        "icons/16x16.png",
        "icons/24x24.png",
        "icons/32x32.png",
        "icons/48x48.png",
        "icons/64x64.png",
        "icons/128x128.png",
        "icons/256x256.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ],
      "windows": {
        "nsis": {
          "installerIcon": "icons/icon.ico",
          "license": "../LICENSE"
        }
      }
    }
  }
}
